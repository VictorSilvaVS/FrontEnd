# Webhook URL para o canal do Microsoft Teams onde você quer postar os relatórios.
# Obtenha isso configurando um "Incoming Webhook" no seu canal do Teams.
TEAMS_WEBHOOK_URL="https://outlook.office.com/webhook/..." 

# Opcional: Se você quiser usar um proxy para enviar requisições
# HTTP_PROXY="http://user:password@proxy.example.com:8080"
# HTTPS_PROXY="http://user:password@proxy.example.com:8080"
