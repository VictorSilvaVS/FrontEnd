# ==============================================================================
# MACHINE MONITORING API - ARQUIVO DE AMBIENTE (ABSOLUTO/SENIOR)
# ==============================================================================
# Renomeie este arquivo para .env na raiz do Frontend.
# Todos os valores abaixo são OBRIGATÓRIOS. A falta de qualquer um
# fará a aplicação falhar durante a inicialização (Engine Fail-Fast).

# --- Configurações do Servidor ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Ambientes e Diretórios ---
# (Caminhos relativos à raiz de onde você executa)
LOGS_DIR=logs
CONFIGS_MACHINES_DIR=configs/machines
DB_PATH=database/production_data.db
PLC_CONFIG_FILE=configs/plc_config.json
STANDBY_CODES_FILE=configs/standby_codes.json

# --- Lógica de Controle (Timers em Segundos) ---
# Frequência de leitura no PLC
COLLECTION_INTERVAL_SECONDS=10
# Frequência com que o desconto da folga no BD ocorre
PROCESSING_INTERVAL_SECONDS=60
# Frequência com que as métricas são empacotadas
REPORTING_INTERVAL_SECONDS=300

# --- Internacionalização e Log ---
TIMEZONE=America/Sao_Paulo
# Valores permitidos: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Integração Webhooks (Teams) ---
TEAMS_WEBHOOK_URL=COLOQUE_URL_DO_TEAMS_AQUI
HTTP_PROXY=
HTTPS_PROXY=
